# ──────────────────────────────────────────────────────────────────────────────
# FlashVault MCP — Environment Variables
# Copy this file to .env.local for local development.
# Set all vars in your Vercel dashboard for production.
# ──────────────────────────────────────────────────────────────────────────────

# REQUIRED: Your wallet address that receives USDC payments from agents.
# Must be a valid EVM address (0x...). Use a Coinbase Wallet or any Base-compatible wallet.
RECIPIENT_ADDRESS=0xYourWalletAddressHere

# REQUIRED: Network to accept payments on.
# Use "base" for mainnet (real USDC), "base-sepolia" for testing (free testnet USDC).
NETWORK=base

# OPTIONAL: x402 payment facilitator URL.
# Default is the official Coinbase/Vercel facilitator — no change needed.
FACILITATOR_URL=https://x402.org/facilitator

# OPTIONAL: Base RPC endpoint.
# Default is the public Base RPC. Use Alchemy/QuickNode for higher reliability.
BASE_RPC_URL=https://mainnet.base.org

# OPTIONAL: Profit-share basis points (100 bps = 1%).
# 500 = 5% of arbitrage net profit is routed back to RECIPIENT_ADDRESS.
# Range: 0–1000 (0%–10%). Default: 500 (5%).
PROFIT_SHARE_BPS=500

# OPTIONAL: CoinGecko API key for higher rate limits on get_market_data.
# Free tier works without a key (30 req/min). Get one at https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# OPTIONAL: Your deployment base URL (used for the landing page MCP endpoint display).
# Set this in Vercel to your actual domain, e.g. https://flashvault.vercel.app
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app
